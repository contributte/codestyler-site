<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="description" content="Visual PHP_CodeSniffer playground - browse rules, check code, generate rulesets">

	<title>{ifset #title}{include #title} | {/ifset}Codestyler</title>

	<script src="https://cdn.tailwindcss.com"></script>
	<script>
		tailwind.config = {
			theme: {
				extend: {
					colors: {
						brand: {
							50: '#eef2ff',
							100: '#e0e7ff',
							200: '#c7d2fe',
							300: '#a5b4fc',
							400: '#818cf8',
							500: '#6366f1',
							600: '#4f46e5',
							700: '#4338ca',
							800: '#3730a3',
							900: '#312e81',
						},
					},
				},
			},
		};
	</script>
	<style>
		.cm-editor { height: 100%; font-size: 14px; }
		.cm-editor .cm-scroller { font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace; }
		.cm-editor.cm-focused { outline: none; }
		::-webkit-scrollbar { width: 8px; height: 8px; }
		::-webkit-scrollbar-track { background: #f1f5f9; }
		::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
		::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
	</style>
	<script type="module" src="/assets/js/app.js"></script>
</head>
<body class="min-h-full bg-gray-50 text-gray-900 antialiased" x-data="layout">
	<header class="bg-white border-b border-gray-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex justify-between items-center h-16">
				<div class="flex items-center gap-8">
					<a href="{link Home:}" class="text-xl font-bold text-indigo-600">
						Codestyler
					</a>
					<nav class="hidden md:flex items-center gap-6">
						<a href="{link Home:}" n:class="'text-gray-600 hover:text-gray-900 transition-colors', $presenter->isLinkCurrent('Home:*') ? 'text-gray-900 font-medium'">
							Home
						</a>
						<a href="{link Sniffs:}" n:class="'text-gray-600 hover:text-gray-900 transition-colors', $presenter->isLinkCurrent('Sniffs:*') ? 'text-gray-900 font-medium'">
							Sniffs
						</a>
						<a href="{link Playground:}" n:class="'text-gray-600 hover:text-gray-900 transition-colors', $presenter->isLinkCurrent('Playground:*') ? 'text-gray-900 font-medium'">
							Playground
						</a>
					</nav>
				</div>
				<div class="flex items-center gap-4">
					<a href="https://github.com/contributte/codestyler" target="_blank" rel="noopener" class="text-gray-500 hover:text-gray-700 transition-colors">
						<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					</a>
				</div>
			</div>
		</div>
	</header>

	<main class="flex-1">
		<div n:ifset="$flashes" n:if="count($flashes) > 0" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
			<div n:foreach="$flashes as $flash" class="rounded-md p-4 {$flash->type === 'error' ? 'bg-red-50 text-red-800' : 'bg-green-50 text-green-800'}">
				{$flash->message}
			</div>
		</div>

		{include #content}
	</main>

	<footer class="bg-white border-t border-gray-200 mt-auto">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
			<p class="text-center text-gray-500 text-sm">
				Built with Nette Framework by <a href="https://contributte.org" class="text-indigo-600 hover:text-indigo-500">Contributte</a>
			</p>
		</div>
	</footer>
</body>
</html>

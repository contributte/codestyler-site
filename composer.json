{
	"name": "contributte/codestyler",
	"description": "CodeSniffer playground",
	"keywords": [
		"codesniffer",
		"codestyle",
		"contributte",
		"nette",
		"playground",
		"php"
	],
	"type": "project",
	"license": "MIT",
	"homepage": "https://github.com/contributte/codestyler",
	"authors": [
		{
			"name": "Milan Felix Sulc",
			"homepage": "https://f3l1x.io"
		}
	],
	"require": {
		"php": ">=8.4",
		"contributte/nella": "^0.3",
		"contributte/ui": "^0.3",
		"slevomat/coding-standard": "^8.25.1",
		"squizlabs/php_codesniffer": "^4.0.1",
		"symfony/process": "^7.0"
	},
	"require-dev": {
		"contributte/qa": "^0.5.0",
		"contributte/phpstan": "^0.4.0",
		"contributte/tester": "^0.5.0",
		"phpunit/phpunit": "^11.5"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests"
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
